{
  "name": "codex-claude-plugin",
  "version": "0.10.1",
  "private": true,
  "type": "module",
  "repository": "https://github.com/filipgutica/codex-claude-plugin.git",
  "engines": {
    "node": ">=20.16.0"
  },
  "scripts": {
    "build:runtime": "node scripts/build-runtime.mjs",
    "check:runtime": "node scripts/build-runtime.mjs --check",
    "postinstall": "lefthook install",
    "stamp-version": "node scripts/stamp-version.mjs",
    "validate-plugins": "node scripts/validate-plugins.mjs",
    "test": "vitest run",
    "check": "pnpm check:runtime && pnpm validate-plugins && pnpm test"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.13.4",
    "lefthook": "^1.11.13",
    "semantic-release": "^24.2.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
